# ==============================================================================
# PROCESADOR DE EVENTOS SÍSMICOS - VARIABLES DE ENTORNO
# ==============================================================================

# Entorno de Ejecución
ENVIRONMENT=production
LOG_LEVEL=INFO

# ==============================================================================
# CONFIGURACIÓN DE BASE DE DATOS (MongoDB)
# ==============================================================================
MONGO_HOST=172.20.0.10
MONGO_PORT=27017
MONGO_DB_NAME=events_db
MONGO_URI=mongodb://172.20.0.10:27017/events_db

# ==============================================================================
# CONFIGURACIÓN DE RED E IPs ESTÁTICAS (Docker Network: 172.20.0.0/16)
# ==============================================================================
INGESTION_HOST=172.20.0.20
INGESTION_PORT=8000

QUERY_HOST=172.20.0.30
QUERY_PORT=8001

AIRFLOW_HOST=172.20.0.40
AIRFLOW_PORT=8080

# ==============================================================================
# CONFIGURACIÓN DE APACHE AIRFLOW
# ==============================================================================
AIRFLOW_SERVERS_USER=admin
AIRFLOW_SERVERS_PASSWORD=admin_secure_pass123
AIRFLOW_SERVERS_EMAIL=admin@processor.local
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__EXECUTOR=SequentialExecutor